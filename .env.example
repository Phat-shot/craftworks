# ── Database ─────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=platform

# ── Server ───────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT (generate: openssl rand -hex 64) ─
JWT_SECRET=CHANGE_ME_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_CHARS_DIFFERENT

# ── App URL (no trailing slash) ──────────
APP_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── Mail (e.g. Mailgun, Brevo, Gmail) ────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM="GamePlatform <noreply@yourdomain.com>"

# ── Security ─────────────────────────────
HASH_SALT=CHANGE_ME_RANDOM_STRING
