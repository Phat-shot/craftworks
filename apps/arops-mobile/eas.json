{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "SERVER_URL": "https://dev.srz.one" }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": { "SERVER_URL": "https://dev.srz.one" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "SERVER_URL": "https://arops.srz.one" }
    }
  },
  "submit": {
    "production": {}
  }
}
