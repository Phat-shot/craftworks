<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Companion-only: requires the phone's Craftworks app, never runs
             standalone. This is the official Wear OS manifest flag for that. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives pairing + game-state pushes from the phone over the
             Data Layer API (MessageClient) — see GameStateListenerService
             for the "/arops/claim" (pairing) and "/arops/state" (match
             state) paths, both under this one prefix (filtered in code via
             event.path, not here).

             BIND_LISTENER, not MESSAGE_RECEIVED: reported bug — phone
             consistently reported a successful send, watch's own node
             check confirmed a reachable phone, yet the claim never
             registered, with no trace of it even being rejected (see
             PairingRepository.lastRejectedToken, which stayed empty). A
             WearableListenerService is bound directly by Play Services via
             BIND_LISTENER; MESSAGE_RECEIVED + a <data> element is an
             intent-broadcast pattern that doesn't apply to this API at all
             — with the wrong action declared, Play Services never
             discovers this service as a listener, so onMessageReceived
             would never fire regardless of connectivity or the message
             ever having been sent. -->
        <service
            android:name=".GameStateListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.BIND_LISTENER" />
            </intent-filter>
        </service>

    </application>
</manifest>
